{
  "name": "panelinha-team-balancer",
  "private": true,
  "version": "1.0.0",
  "description": "App para balancear times de vôlei misto e registrar partidas semanais.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint:eslint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --import tsx --test src/logic/balancing.test.ts src/logic/tournament.test.ts src/logic/migrations.test.ts src/services/supabase/mappers.test.ts src/services/supabase/schema.test.ts src/services/supabase/syncService.test.ts src/services/supabase/upsertConflict.test.ts src/logic/syncStatus.test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.2.6",
    "recharts": "^3.8.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "daisyui": "^5.5.20",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.2.0"
  }
}
